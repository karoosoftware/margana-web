# S3 buckets used by the app
VITE_MARGANA_WORD_GAME=margana-word-game-preprod
VITE_MARGANA_GAME_RESULTS=margana-game-results-preprod
# NEW: Analytics bucket for usage tracking (client uploads batches here)
VITE_MARGANA_ANALYTICS_BUCKET=margana-analytics-preprod
VITE_USAGE_ENABLED=false
VITE_USAGE_RETENTION_DAYS=7
VITE_USAGE_DEBUG_LOG=true

# Analytics typing aggregates (preferred)
VITE_USAGE_TYPING_AGG=true
VITE_USAGE_TYPING_AGG_DEBOUNCE_MS=5000
VITE_USAGE_TYPING_AGG_BURST_MS=800
VITE_USAGE_TYPING_AGG_BURST_MIN=3
VITE_USAGE_TYPING_AGG_MIN_KEYS=1
VITE_USAGE_SCROLL_SAMPLE_MS=1000

# Highlight usage aggregates (ValidWords highlight panel)
VITE_USAGE_HIGHLIGHT_AGG=true
VITE_USAGE_HIGHLIGHT_DEBOUNCE_MS=5000

# Shuffle aggregates (Anagram shuffle/reset windows)
VITE_USAGE_SHUFFLE_AGG=true
VITE_USAGE_SHUFFLE_AGG_DEBOUNCE_MS=5000
VITE_USAGE_SHUFFLE_AGG_MIN_SHUFFLES=1

# Legacy per-letter engagement pings (keep off when typing_agg is on)
VITE_USAGE_LETTER_INPUTS=false
VITE_USAGE_LETTER_THROTTLE_MS=1000

# Scoring configuration
# Fixed anagram bonus points when player hits the day's target length (used by Lambda and generator)
MARGANA_ANAGRAM_BONUS=20

# Disable XOR precheck
VITE_DISABLE_XOR_PRECHECK=false
